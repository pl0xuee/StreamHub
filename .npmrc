# castLabs "Electron for Content Security" (ECS) is installed from a git source
# (electron -> castlabs/electron-releases#vXX+wvcus in package.json). npm 12 blocks
# git sources by default, so allow them here. Its install script (which downloads the
# prebuilt Electron+Widevine binary) is approved via "allowScripts" in package.json.
allow-git=all
